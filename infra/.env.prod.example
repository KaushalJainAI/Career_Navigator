# Copy to infra/.env and fill in. Consumed by docker-compose.prod.yml.
# NEVER commit the filled-in infra/.env — it holds live secrets.

# --- Django core ---
DJANGO_SETTINGS_MODULE=config.settings.prod
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=
DEBUG=False
# Comma-separated. Include your domain + EC2 public IP + `backend` (compose-internal).
ALLOWED_HOSTS=your-domain.com,backend
# Frontend origin(s) for CORS/WS. Your public site only.
CORS_ALLOWED_ORIGINS=https://your-domain.com
FRONTEND_URL=https://your-domain.com

# Flip on once TLS terminates in front of nginx (Let's Encrypt / ALB).
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# --- Database (Postgres in prod) ---
POSTGRES_DB=career_navigator
POSTGRES_USER=cn
POSTGRES_PASSWORD=

# --- Credentials vault (AES-GCM). LOSING THIS BRICKS ALL STORED CREDENTIALS. ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
CREDENTIAL_ENCRYPTION_KEY=

# --- LLM: NVIDIA NIM (launch provider) ---
AI_PROVIDER=nvidia
AI_FALLBACK_PROVIDER=nvidia
NVIDIA_API_KEY=
NVIDIA_GUEST_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1

# --- Job source API keys (set the ones you have) ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
JSEARCH_RAPIDAPI_KEY=
GREENHOUSE_TOKENS=
LEVER_TOKENS=

# --- Google OAuth (must match Google Console redirect URI) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/auth/google/callback
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback

# --- Email (Resend) ---
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=no-reply@your-domain.com

# --- Public HTTP port (set 80, or a high port if behind an external LB) ---
PUBLIC_HTTP_PORT=80

# Stripe stays disabled for launch — leave blank.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
