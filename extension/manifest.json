{
  "manifest_version": 3,
  "name": "Career Navigator",
  "version": "0.1.0",
  "description": "Capture jobs and contacts from the pages you visit, sync to your Career Navigator dashboard.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://www.linkedin.com/jobs/*",
    "https://www.linkedin.com/in/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://www.naukri.com/*",
    "https://unstop.com/*",
    "https://*.mercor.com/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Career Navigator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["content-linkedin-jobs.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content-linkedin-profile.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.greenhouse.io/*"],
      "js": ["content-greenhouse.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobs.lever.co/*"],
      "js": ["content-lever.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.naukri.com/*"],
      "js": ["content-naukri.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://unstop.com/*"],
      "js": ["content-unstop.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.mercor.com/*"],
      "js": ["content-mercor.js"],
      "run_at": "document_idle"
    }
  ]
}
