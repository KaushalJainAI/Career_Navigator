DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=django-insecure-replace-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOW_ALL_ORIGINS=True

# Database (defaults to sqlite if blank)
DATABASE_URL=

# Redis / Celery / Channels
REDIS_URL=redis://localhost:6379/0
USE_REDIS_CHANNEL_LAYER=False
RUN_INGESTION_ASYNC=False

# Credentials vault encryption — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-strong-secret

# NVIDIA NIM guest pool (AIAAS pattern)
NVIDIA_API_KEY=
NVIDIA_GUEST_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
GUEST_CHAT_MAX_TOKENS=200000

# AI provider transport
# For a hosted/SaaS deploy use AI_PROVIDER=nvidia (set NVIDIA_API_KEY below).
# AI_PROVIDER=codex_cli is local-only — needs `codex login` on the machine and
# is not for shared SaaS use.
AI_PROVIDER=nvidia
AI_FALLBACK_PROVIDER=nvidia
CODEX_CLI_COMMAND=codex
CODEX_CLI_MODEL=
CODEX_CLI_SANDBOX=read-only
CODEX_CLI_TIMEOUT_SECONDS=120
CODEX_CLI_WORKDIR=
NVIDIA_TIMEOUT_SECONDS=120
NVIDIA_MAX_TOKENS=2048

# Job sources
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
JSEARCH_RAPIDAPI_KEY=
# Comma-separated list of Greenhouse board tokens (e.g. "stripe,airbnb,figma")
GREENHOUSE_TOKENS=
LEVER_TOKENS=

# Portal automation (no-API, browser-driven sources). Off by default; set
# PORTAL_SCRAPER_ENABLED=True and run `playwright install chromium` to use it.
# Session cookies are the USER'S OWN session (not a shared scraping account) —
# paste the value of the named auth cookie from a logged-in browser, or supply
# sessions per-user via POST /api/v1/portals/<name>/session/.
PORTAL_SCRAPER_ENABLED=False
PORTAL_SCRAPER_HEADLESS=True
PORTAL_SCRAPER_MIN_DELAY_SECONDS=1.5
PORTAL_SCRAPER_MAX_RESULTS=25
LINKEDIN_SESSION_COOKIE=
NAUKRI_SESSION_COOKIE=
UNSTOP_SESSION_COOKIE=
YC_SESSION_COOKIE=

# Notifications
RESEND_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@career-navigator.local

# Google OAuth (AIAAS pattern)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
